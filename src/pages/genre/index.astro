---
import Base from "../../layouts/Base.astro";
import GenreGuide from "../../components/interactive/GenreGuide/GenreGuide";
import { lenses } from "../../data/lenses";
import { pickGenreFields } from "../../utils/pickGenreFields";

const genreLenses = lenses.map(pickGenreFields);
---

<Base
  title="Which Lens for Your Genre? — Wuseria"
  description="Landscape, portrait, street, astro — see which Fujifilm lenses score highest for the genres you shoot."
>
  <GenreGuide client:load lenses={genreLenses} defaultGenre="nightscape" />
</Base>
