---
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import type { ScoredGenre } from "../../types/genre";
import Base from "../../layouts/Base.astro";
import GenreGuide from "../../components/interactive/GenreGuide/GenreGuide";
import { genreConfigs } from "../../data/genres";
import { lenses } from "../../data/lenses";

export const getStaticPaths = (() => {
  const genres: ScoredGenre[] = [
    "astro", "landscape", "architecture", "street",
    "travel", "portrait", "sport", "wildlife",
  ];
  return genres.map((genre) => ({
    params: { genre },
    props: { genre },
  }));
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
const { genre } = Astro.props as Props;
const config = genreConfigs[genre as ScoredGenre];
---

<Base
  title={`${config.name} — Genre Guide — Fuji.me!`}
  description={`Best Fujifilm lenses for ${config.name.toLowerCase()}, scored by optical performance. ${config.description}`}
>
  <GenreGuide
    client:load
    lenses={lenses}
    defaultGenre={genre as ScoredGenre}
  />
</Base>
