---
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import type { Genre } from "../../types/genre";
import Base from "../../layouts/Base.astro";
import GenreGuide from "../../components/interactive/GenreGuide/GenreGuide";
import { genreConfigs } from "../../data/genres";
import { lenses } from "../../data/lenses";
import { pickGenreFields } from "../../utils/pickGenreFields";

const genreLenses = lenses.map(pickGenreFields);

export const getStaticPaths = (() => {
  const genres: Genre[] = [
    "nightscape",
    "landscape",
    "architecture",
    "street",
    "travel",
    "portrait",
    "sport",
    "wildlife",
    "macro",
  ];
  return genres.map((genre) => ({
    params: { genre },
    props: { genre },
  }));
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
const { genre } = Astro.props as Props;
const config = genreConfigs[genre as Genre];
---

<Base
  title={`Best Lenses for ${config.name} — Wuseria`}
  description={`Top-scoring Fujifilm lenses for ${config.name.toLowerCase()}, ranked by lab-tested optical performance. ${config.description}`}
>
  <GenreGuide client:load lenses={genreLenses} defaultGenre={genre as Genre} />
</Base>
