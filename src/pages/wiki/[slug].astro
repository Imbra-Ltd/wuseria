---
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";

export const getStaticPaths = (async () => {
  const entries = await getCollection("wiki");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, allEntries: entries },
  }));
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
const { entry, allEntries } = Astro.props as Props;
const { Content } = await render(entry);

const relatedEntries = entry.data.related
  ? allEntries.filter((e) => entry.data.related!.includes(e.id))
  : [];

const canonicalUrl = new URL(`/wiki/${entry.id}`, Astro.site);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: entry.data.title,
  description: entry.data.summary,
  url: canonicalUrl.href,
  publisher: {
    "@type": "Organization",
    name: "Wuseria",
    url: Astro.site?.href,
  },
};
---

<Base
  title={`${entry.data.title} — Wiki — Wuseria`}
  description={entry.data.summary}
>
  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(jsonLd)}
  />
  <article class="wiki-article">
    <div class="title-row">
      <h1>{entry.data.title}</h1>
      {
        entry.data.fullTitle && entry.data.fullTitle !== entry.data.title && (
          <span class="full-title">{entry.data.fullTitle}</span>
        )
      }
      <span class="category-badge">{entry.data.categories.join(" / ")}</span>
    </div>
    <p class="summary">{entry.data.summary}</p>

    <div class="body">
      <Content />
    </div>

    {
      relatedEntries.length > 0 && (
        <nav class="related" aria-label="Related articles">
          <h2>Related</h2>
          <ul class="related-list">
            {relatedEntries.map((r) => (
              <li>
                <a href={`/wiki/${r.id}`}>{r.data.title}</a>
              </li>
            ))}
          </ul>
        </nav>
      )
    }

    <a href="/wiki" class="back-link">Back to Wiki</a>
  </article>
</Base>

<style>
  .wiki-article {
    max-width: 48rem;
  }

  .title-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    flex-wrap: wrap;
    margin-bottom: var(--space-xs);
  }

  .full-title {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
  }

  .category-badge {
    margin-left: auto;
    font-size: 0.6875rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background: var(--color-bg-surface);
    padding: 1px 6px;
    font-family: var(--font-mono);
    white-space: nowrap;
  }

  .summary {
    color: var(--color-text-muted);
    font-size: var(--font-size-lg);
    margin-bottom: var(--space-xl);
  }

  .body {
    line-height: 1.8;
    margin-bottom: var(--space-2xl);
  }

  .body :global(p) {
    margin-bottom: var(--space-md);
  }

  .body :global(h2) {
    font-size: var(--font-size-xl);
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-sm);
  }

  .body :global(h3) {
    font-size: var(--font-size-lg);
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
  }

  .body :global(ul),
  .body :global(ol) {
    padding-left: var(--space-lg);
    margin-bottom: var(--space-md);
  }

  .body :global(li) {
    margin-bottom: var(--space-xs);
  }

  .body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: var(--space-md);
    font-size: var(--font-size-sm);
  }

  .body :global(th),
  .body :global(td) {
    padding: var(--space-xs) var(--space-sm);
    border: 1px solid var(--color-border);
    text-align: left;
  }

  .body :global(th) {
    background: var(--color-bg-surface);
    font-weight: 600;
  }

  .body :global(strong) {
    color: var(--color-text);
  }

  .body :global(code) {
    background: var(--color-bg-surface);
    padding: 1px 4px;
    border-radius: 2px;
    font-size: var(--font-size-sm);
  }

  .body :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-md);
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }

  .related {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .related h2 {
    font-size: var(--font-size-lg);
    margin-bottom: var(--space-sm);
  }

  .related-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .related-list a {
    color: var(--color-link);
    padding: var(--space-xs) var(--space-sm);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-size: var(--font-size-sm);
  }

  .related-list a:hover {
    color: var(--color-link-hover);
    border-color: var(--color-accent);
  }

  .back-link {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .back-link:hover {
    color: var(--color-link);
  }
</style>
