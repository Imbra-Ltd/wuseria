---
import Base from "../../layouts/Base.astro";
import { wiki } from "../../data/wiki";

const sorted = [...wiki].sort((a, b) => a.title.localeCompare(b.title));
---

<Base title="Wiki — Fuji.me!" description="Photography terms and concepts explained for Fujifilm shooters.">
  <h1>Wiki</h1>
  <p class="subtitle">A-Z index of photography terms and concepts.</p>

  <ul class="wiki-list">
    {sorted.map((entry) => (
      <li class="wiki-item">
        <a href={`/wiki/${entry.slug}`} class="wiki-link">
          <span class="wiki-title">{entry.title}</span>
          <span class="wiki-summary">{entry.summary}</span>
        </a>
      </li>
    ))}
  </ul>
</Base>

<style>
  .subtitle {
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
  }

  .wiki-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .wiki-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    color: var(--color-text);
    text-decoration: none;
  }

  .wiki-link:hover {
    background-color: var(--color-bg-hover);
    border-color: var(--color-accent);
  }

  .wiki-title {
    font-weight: 600;
    color: var(--color-link);
  }

  .wiki-link:hover .wiki-title {
    color: var(--color-link-hover);
  }

  .wiki-summary {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }
</style>
