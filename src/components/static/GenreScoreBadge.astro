---
interface Props {
  mark: number;
}

const { mark } = Astro.props;
const palette = [
  "",
  "var(--color-mark-1)",
  "var(--color-mark-2)",
  "var(--color-mark-3)",
  "var(--color-mark-4)",
  "var(--color-mark-5)",
];
const color = palette[mark] || "var(--color-mark-fallback)";
const filled = "●".repeat(mark);
const empty = "○".repeat(5 - mark);
---

<span
  class="mark-pips"
  style={`color: ${color};`}
  aria-label={`Mark ${mark} of 5`}
>
  {filled}<span class="mark-empty">{empty}</span>
</span>

<style>
  .mark-pips {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
  }

  .mark-empty {
    opacity: 0.3;
  }
</style>
